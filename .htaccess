# ==============================================================
# CONFIGURAÇÃO MÍNIMA PARA FUNCIONAMENTO
# ==============================================================

# Desativa listagem de diretórios
Options -Indexes

# Ativa engine de rewrite
RewriteEngine On

# Define os arquivos padrão
DirectoryIndex index.php

# Remapeia todas as requisições para index.php (roteador principal)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
